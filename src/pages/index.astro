---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Únete al Equipo — Instituto Osbord LLC"
  description="Buscamos Closers de alto rendimiento. Trabajo 100% remoto, alto compromiso y comisiones sin límite. Aplica ahora."
>
  <!-- ═══════════════════════════════════════════ -->
  <!-- NAVBAR                                      -->
  <!-- ═══════════════════════════════════════════ -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-20 md:h-24">
        <a href="#hero" class="flex items-center gap-3 group">
          <img 
            src="/logo.png" 
            alt="Instituto Osbord Logo" 
            class="w-12 h-12 md:w-14 md:h-14 object-contain transition-transform duration-300 group-hover:scale-105"
          />
          <span class="font-display font-semibold text-sm md:text-base text-white/90 tracking-wide">
            INSTITUTO OSBORD
          </span>
        </a>
        <a
          href="#aplicar"
          class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 bg-gold/10 border border-gold/30 rounded-full text-gold text-sm font-medium hover:bg-gold hover:text-navy transition-all duration-300"
        >
          <span>Aplicar Ahora</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════ -->
  <!-- HERO SECTION                                -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden noise">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-gradient-to-br from-navy-800 via-navy to-navy-700"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-gold/5 rounded-full blur-[120px] animate-float"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-gold/3 rounded-full blur-[100px] animate-float-delay"></div>

    <!-- Grid Pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(197,160,89,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(197,160,89,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <!-- Decorative Lines -->
    <div class="absolute top-1/4 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/20 to-transparent"></div>
    <div class="absolute bottom-1/3 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/10 to-transparent"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-24">
      <!-- Logo Central -->
      <div class="inline-block mb-6 animate-fade-in">
        <img 
          src="/logo.png" 
          alt="Instituto Osbord Shield" 
          class="w-24 h-24 sm:w-28 sm:h-28 mx-auto object-contain drop-shadow-[0_0_20px_rgba(197,160,89,0.2)]"
        />
      </div>

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-8 animate-fade-in" style="animation-delay: 0.1s;">
        <span class="w-2 h-2 bg-gold rounded-full animate-pulse"></span>
        <span class="text-gold/90 text-xs sm:text-sm font-medium tracking-wider uppercase">Proceso de Selección Activo</span>
      </div>

      <!-- Title -->
      <h1 class="font-display font-black text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[1.1] mb-6 animate-fade-in-up">
        Únete a la Élite<br />
        <span class="text-gradient-gold">de Ventas Global</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl md:text-2xl text-white/60 max-w-2xl mx-auto mb-10 font-light leading-relaxed animate-fade-in-up" style="animation-delay: 0.2s;">
        Buscamos <strong class="text-white/90 font-semibold">Closers de alto rendimiento</strong> para transformar leads en casos de éxito.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in-up" style="animation-delay: 0.4s;">
        <a
          href="#aplicar"
          class="group relative inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-gold to-gold-300 text-navy font-bold text-base rounded-xl hover:shadow-[0_0_40px_rgba(197,160,89,0.3)] transition-all duration-500 hover:-translate-y-0.5 animate-pulse-gold"
        >
          <span>Quiero Aplicar</span>
          <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="#condiciones"
          class="inline-flex items-center gap-2 px-8 py-4 border border-white/10 rounded-xl text-white/70 hover:text-white hover:border-white/30 transition-all duration-300 text-base"
        >
          <span>Conocer más</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4 sm:gap-8 max-w-lg mx-auto mt-16 pt-8 border-t border-white/5 animate-fade-in-up" style="animation-delay: 0.6s;">
        <div class="text-center">
          <div class="font-display font-bold text-2xl sm:text-3xl text-gradient-gold">100%</div>
          <div class="text-white/40 text-xs sm:text-sm mt-1">Remoto</div>
        </div>
        <div class="text-center">
          <div class="font-display font-bold text-2xl sm:text-3xl text-gradient-gold">∞</div>
          <div class="text-white/40 text-xs sm:text-sm mt-1">Ingresos</div>
        </div>
        <div class="text-center">
          <div class="font-display font-bold text-2xl sm:text-3xl text-gradient-gold">Alta</div>
          <div class="text-white/40 text-xs sm:text-sm mt-1">Velocidad</div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 border-2 border-white/20 rounded-full flex justify-center pt-2">
        <div class="w-1 h-3 bg-gold/60 rounded-full animate-pulse"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- SOBRE EL INSTITUTO                         -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="instituto" class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy via-navy-600 to-navy"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gold/3 rounded-full blur-[150px]"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center mb-16 reveal">
        <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase text-gold border border-gold/20 bg-gold/5 mb-4">
          Quiénes Somos
        </span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl md:text-5xl mb-6">
          Instituto <span class="text-gradient-gold">Osbord</span>
        </h2>
        <div class="w-20 h-1 bg-gradient-to-r from-gold/0 via-gold to-gold/0 mx-auto mb-8"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <!-- Text Content -->
        <div class="reveal">
          <p class="text-white/70 text-base sm:text-lg leading-relaxed mb-6">
            <strong class="text-white">Instituto Osbord LLC</strong> es una empresa líder en el sector <strong class="text-gold">EdTech global</strong>, dedicada a transformar la vida de profesionales y emprendedores a través de programas educativos de alto impacto.
          </p>
          <p class="text-white/60 text-base sm:text-lg leading-relaxed mb-8">
            Desde nuestra sede en Wyoming, USA, operamos a nivel internacional, conectando talento con oportunidades de crecimiento sin fronteras. Nuestro equipo de ventas es el motor que impulsa esta misión.
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="px-4 py-2 glass rounded-lg text-sm text-white/80 flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Alcance Global
            </span>
            <span class="px-4 py-2 glass rounded-lg text-sm text-white/80 flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479L12 21l-5.825-3.943a12.083 12.083 0 01.665-6.48L12 14z" />
              </svg>
              EdTech Premium
            </span>
            <span class="px-4 py-2 glass rounded-lg text-sm text-white/80 flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
              Alto Impacto
            </span>
          </div>
        </div>

        <!-- Visual Card -->
        <div class="reveal">
          <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-gold/20 via-gold/10 to-gold/20 rounded-2xl blur-lg group-hover:blur-xl transition-all duration-500 opacity-0 group-hover:opacity-100"></div>
            <div class="relative glass rounded-2xl p-8 md:p-10">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-gold to-gold-300 flex items-center justify-center shrink-0">
                  <svg class="w-7 h-7 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-display font-bold text-xl text-white">Nuestra Misión</h3>
                  <p class="text-gold/80 text-sm">Transformar vidas a través de la educación</p>
                </div>
              </div>
              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <div class="w-6 h-6 rounded-full bg-gold/10 flex items-center justify-center mt-0.5 shrink-0">
                    <!-- Icono formal de Sombrero de Graduación / Educación -->
                    <svg class="w-3.5 h-3.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479L12 21l-5.825-3.943a12.083 12.083 0 01.665-6.48L12 14z" />
                    </svg>
                  </div>
                  <p class="text-white/60 text-sm">Programas educativos que generan resultados reales y medibles</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-6 h-6 rounded-full bg-gold/10 flex items-center justify-center mt-0.5 shrink-0">
                    <!-- Icono formal de Conexión / Red Global -->
                    <svg class="w-3.5 h-3.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <p class="text-white/60 text-sm">Equipo multicultural distribuido en más de 15 países</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-6 h-6 rounded-full bg-gold/10 flex items-center justify-center mt-0.5 shrink-0">
                    <!-- Icono formal de Rendimiento / Crecimiento -->
                    <svg class="w-3.5 h-3.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                    </svg>
                  </div>
                  <p class="text-white/60 text-sm">Cultura de excelencia, rendimiento y crecimiento continuo</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- EL PUESTO Y COMPROMISO                      -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="condiciones" class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-800 via-navy to-navy"></div>
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-gold/3 rounded-full blur-[120px]"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase text-gold border border-gold/20 bg-gold/5 mb-4">
          Compromiso y Rendimiento
        </span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl md:text-5xl mb-4">
          Velocidad y <span class="text-gradient-gold">Enfoque Profesional</span>
        </h2>
        <p class="text-white/50 text-base sm:text-lg max-w-2xl mx-auto">
          No buscamos trabajo de medio tiempo. Requerimos profesionales altamente comprometidos con la respuesta inmediata y el cierre.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8 reveal">
        <!-- Remote -->
        <div class="group relative overflow-hidden rounded-2xl">
          <div class="absolute inset-0 bg-gradient-to-br from-gold/10 to-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative glass rounded-2xl p-8 h-full flex gap-6 items-start hover:border-gold/20 transition-all duration-500">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-gold/20 to-gold/5 flex items-center justify-center shrink-0">
              <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-xl text-white mb-2">100% Remoto</h3>
              <p class="text-white/50 text-sm leading-relaxed">Trabaja desde cualquier lugar, con acceso instantáneo a nuestro sistema de leads. La distancia no frena la velocidad de tu ejecución.</p>
            </div>
          </div>
        </div>

        <!-- Respuesta Inmediata -->
        <div class="group relative overflow-hidden rounded-2xl">
          <div class="absolute inset-0 bg-gradient-to-br from-gold/10 to-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative glass rounded-2xl p-8 h-full flex gap-6 items-start hover:border-gold/20 transition-all duration-500">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-gold/20 to-gold/5 flex items-center justify-center shrink-0">
              <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-xl text-white mb-2">Contacto Inmediato</h3>
              <p class="text-white/50 text-sm leading-relaxed">La clave es el contacto al instante. Debes estar listo para llamar al lead caliente de inmediato en el momento en que se registra y solicita información.</p>
            </div>
          </div>
        </div>

        <!-- Amplia Cobertura -->
        <div class="group relative overflow-hidden rounded-2xl">
          <div class="absolute inset-0 bg-gradient-to-br from-gold/10 to-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative glass rounded-2xl p-8 h-full flex gap-6 items-start hover:border-gold/20 transition-all duration-500">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-gold/20 to-gold/5 flex items-center justify-center shrink-0">
              <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-xl text-white mb-2">Horario Amplio e Intensivo</h3>
              <p class="text-white/50 text-sm leading-relaxed">Requerimos profesionales dispuestos a cubrir amplias ventanas horarias para asegurar que ningún lead calificado quede sin atención oportuna.</p>
            </div>
          </div>
        </div>

        <!-- Alto Compromiso -->
        <div class="group relative overflow-hidden rounded-2xl">
          <div class="absolute inset-0 bg-gradient-to-br from-gold/10 to-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative glass rounded-2xl p-8 h-full flex gap-6 items-start hover:border-gold/20 transition-all duration-500">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-gold/20 to-gold/5 flex items-center justify-center shrink-0">
              <!-- Icono: Diana / Target (Enfoque en Resultados) -->
              <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <circle cx="12" cy="12" r="10" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="12" cy="12" r="6" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="12" cy="12" r="2" fill="currentColor" stroke="none" />
              </svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-xl text-white mb-2">Enfoque en Resultados</h3>
              <p class="text-white/50 text-sm leading-relaxed">Buscamos un nivel de compromiso profesional de tiempo completo. Valoramos la perseverancia y la tenacidad ante cada objeción.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- MODELO DE COMPENSACIÓN                      -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="compensacion" class="relative py-20 md:py-28 overflow-hidden noise">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-900 via-navy-800 to-navy"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gold/5 rounded-full blur-[150px]"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="reveal">
        <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase text-gold border border-gold/20 bg-gold/5 mb-4">
          Compensación
        </span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl md:text-5xl mb-6">
          Crecimiento <span class="text-gradient-gold">Sin Techos</span>
        </h2>

        <div class="glass rounded-2xl p-8 md:p-12 mb-8">
          <p class="text-xl sm:text-2xl md:text-3xl font-display font-bold text-white leading-relaxed mb-6">
            Modelo 100% basado en <span class="text-gradient-gold">comisiones de alto impacto</span>.
          </p>
          <p class="text-white/60 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto mb-8">
            Tu ambición define tu ingreso. Sin límites, sin restricciones, solo resultados. Cada cierre es una recompensa directa a tu esfuerzo y habilidad.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div class="p-6 rounded-xl bg-white/[0.03] border border-white/5 flex flex-col items-center">
              <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center mb-3">
                <!-- Icono de Llave / Oportunidad (Sin Límites) -->
                <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
                </svg>
              </div>
              <div class="text-xs text-gold uppercase tracking-wider mb-1 font-semibold">Monto de Impacto</div>
              <h4 class="font-display font-bold text-white mb-2">Sin Límites</h4>
              <p class="text-white/40 text-sm">Tu ingreso no tiene techo. Gana en proporción a tu desempeño.</p>
            </div>
            <div class="p-6 rounded-xl bg-white/[0.03] border border-white/5 flex flex-col items-center">
              <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center mb-3">
                <!-- Icono: Signo de Dólar (Alto Ticket) -->
                <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <circle cx="12" cy="12" r="9" stroke-linecap="round" stroke-linejoin="round" />
